<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>{{LAUNCHD_PREFIX}}.telegram-bot</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{NODE_PATH}}</string>
        <string>{{VAULT_PATH}}/scripts/telegram-bot.js</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>{{NODE_PATH}}/../:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>{{VAULT_PATH}}</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>{{VAULT_PATH}}/logs/telegram-bot-out.log</string>

    <key>StandardErrorPath</key>
    <string>{{VAULT_PATH}}/logs/telegram-bot-err.log</string>

    <key>ThrottleInterval</key>
    <integer>5</integer>
</dict>
</plist>
