# Obsidian vault content — notes are personal, not code
*.md
!.github/*.md
!README.md

# Obsidian internals
.obsidian/
.trash/

# Vault folders (PARA) — but allow Templates through
# Inbox paths: 0-Inbox/ (legacy pre-PARA) and 3-Resources/Inbox/ (current inbox)
# 0-Inbox/ contains older clips (~7 files). 3-Resources/ is broader (resources + inbox).
0-Inbox/
1-Projects/
2-Areas/
3-Resources/
4-Archive/
Attachments/
Daily/
!Templates/
!Templates/*.json
Dashboard.md
Projects.md
Scratchpad.md
*.canvas
*.kanban
*.base

# Keep the README and agent instructions
!README.md
!AGENTS.md

# Keep all pi-agent config (overrides *.md exclusion above)
!.pi-agent/
!.pi-agent/**
!.pi-agent/**/*.md

# Excalidraw logs
excalidraw.log
logs/*.log

# API keys and secrets
*-config.json
!*-config.example.json

# Pi runtime data
.pi/messenger/

# Vault Keeper runtime state
.vaultkeeper-state.json

# OS junk
.DS_Store
Thumbs.db

# Node
node_modules/
package-lock.json

# Temp files
*.tmp
tmp/

# Sessions
--session/
pi-cockpit/hub/node_modules/

# Claude Code worktrees & local state
.claude/

# Hub logs
pi-cockpit/logs/
logs/

# Local agent/tool state
.opencode/
.sisyphus/

# pi-agent runtime state (don't commit these subdirs even if they appear)
.pi-agent/**/context/
.pi-agent/**/memory/
.pi-agent/**/run.log
.pi-agent/**/auth.json
.pi-agent/**/telegram.json
.pi-agent/**/sessions/
.pi-agent/**/tmp/
.pi-agent/**/run-history.jsonl
